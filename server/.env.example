# Server Configuration
PORT=8000

# MongoDB Configuration
# Replace with your local MongoDB URI (e.g., mongodb://localhost:27017/interviewiq) or MongoDB Atlas URI
MONGODB_URL=your_mongodb_connection_uri_here

# JWT Configuration
# A random secret string used to sign JWT authentication tokens
JWT_SECRET=your_jwt_secret_key_here

# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/ (used for LLM queries to evaluate candidate answers)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Razorpay Configuration
# Used for processing plan payments and adding credits to users
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
